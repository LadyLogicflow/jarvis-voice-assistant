[Unit]
Description=JARVIS Personal Assistant
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=__USER__
WorkingDirectory=__REPO__
ExecStart=__REPO__/.venv/bin/python server.py
Restart=on-failure
RestartSec=10
StandardOutput=append:__REPO__/jarvis.log
StandardError=append:__REPO__/jarvis.log
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
