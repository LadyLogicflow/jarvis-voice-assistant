# Jarvis Voice Assistant - Secret Environment Variables
#
# Copy this file to .env and fill in your real values.
# .env is gitignored and must NEVER be committed.
#
# Anthropic API Key for Claude Haiku (the "brain")
# Obtain at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# ElevenLabs API Key for text-to-speech voice
# Obtain at: https://elevenlabs.io
ELEVENLABS_API_KEY=sk_...

# Optional: ElevenLabs voice ID (overrides config.json default)
# Find your voice ID in the ElevenLabs voice library.
# ELEVENLABS_VOICE_ID=rDmv3mOhK6TnhYWckFaD

# Optional: Todoist API token for task integration
# Obtain at: https://app.todoist.com/app/settings/integrations/developer
TODOIST_API_TOKEN=

# Optional: Picovoice access key for wake-word trigger
# Obtain a free key at: https://console.picovoice.ai/
PICOVOICE_ACCESS_KEY=

# Optional: shared secret to protect /activate, /show, /hide endpoints
# (relevant only if Jarvis is reachable beyond localhost). Empty = endpoints open.
JARVIS_AUTH_TOKEN=

# Optional: IMAP password — only relevant when mail_backend == "imap" in
# config.json. Use a Gmail / Outlook *app password*, not your account
# password.
IMAP_PASSWORD=

# Optional: iCloud CardDAV Kontakt-Sync (Pi-kompatibel, kein AppleScript nötig)
# App-spezifisches Passwort: appleid.apple.com → Sicherheit → App-spezifische Passwörter
ICLOUD_APPLE_ID=
ICLOUD_APP_PASSWORD=

# Optional: Telegram-Bot-Token (issue #47). Generated via @BotFather
# in Telegram (/newbot). When empty, the Telegram channel stays off.
TELEGRAM_BOT_TOKEN=

# Note: browser headless mode is configured in config.json ("browser_headless": true/false),
# not via env variable. Set it to true on headless servers (SSH, CI) without a display.

# Mail-Monitor (issue #48): one IMAP_PASSWORD per account in
# config.json's mail_monitor_accounts. Naming: IMAP_PASSWORD_<NAME>
# where <NAME> is the account name uppercased and non-alnum -> "_".
# Example accounts "Apple" + "HILO":
# IMAP_PASSWORD_APPLE=xxxx-xxxx-xxxx-xxxx
# IMAP_PASSWORD_HILO=app-password-here

# Optional: Bring! Einkaufsliste (issue #123).
# Login-Daten des Bring!-Kontos. Wenn leer, ist die Bring!-Integration deaktiviert.
BRING_EMAIL=
BRING_PASSWORD=

# Optional: Picnic Lieferservice (issue #126).
# Login-Daten des Picnic-Kontos (DE). Wenn leer, ist [ACTION:PICNICORDER] deaktiviert.
PICNIC_EMAIL=
PICNIC_PASSWORD=

# Optional: BelegSortierung-API (Issue #234).
# API-Key fuer den automatischen Steuerbeleg-Upload. URL kommt aus config.json.
# Wenn leer, ist die BelegSortierung-Integration deaktiviert (kein Crash).
BELEGSORTIERUNG_API_KEY=your_api_key_here

# Optional: Lokales Qwen-LLM-Backend via OpenAI-kompatibler API (Issue #249).
# Sascha betreibt qwen3.5-35b lokal im Pandora-Netz via Ollama.
# Wenn erreichbar: wird fuer Personenkontext-Synthese, Namenserkennung
# in Terminen und Morning Briefing genutzt (kostenlos + schneller als Haiku).
# Fallback auf Claude Haiku wenn Qwen nicht erreichbar oder QWEN_BASE_URL leer.
QWEN_BASE_URL=http://100.66.247.110:11435/v1
QWEN_MODEL_ID=qwen3.5-35b
